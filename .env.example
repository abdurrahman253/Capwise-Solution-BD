# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB Atlas — server only
MONGODB_URI=
MONGODB_DB_NAME=capwisebd

# Resend transactional email — server only
# onboarding@resend.dev can only send to the email attached to the Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Capwise Website <onboarding@resend.dev>
CONSULTATION_TO_EMAIL=
CONSULTATION_REPLY_TO=info@capwisebd.com
SEND_CLIENT_ACKNOWLEDGEMENT=false
RESEND_WEBHOOK_SECRET=

# Optional: enable the email preview route in production only when deliberately needed
ENABLE_EMAIL_PREVIEW=false

# Optional privacy and shared abuse protection
SECURITY_HASH_SALT=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional sitemap review date (ISO format, for example 2026-07-23)
CONTENT_LAST_REVIEWED_AT=

# Optional search verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Optional official social profiles after client confirmation
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
